{
  "name": "paragonai-landing-page",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "husky",
    "dev": "next dev --turbopack",
    "admin:status": "tsx scripts/payload-admin.ts status",
    "admin:create": "tsx scripts/payload-admin.ts create",
    "admin:reset-password": "tsx scripts/payload-admin.ts reset-password",
    "build": "next build",
    "start": "next start",
    "check": "biome check --write .",
    "type-check": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "generate:types": "yarn payload generate:types",
    "generate:schema": "yarn payload generate:db-schema",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "graphql": "^16.14.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "payload": "^3.85.0",
    "postprocessing": "^6.39.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.10.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "sass": "^1.87.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.1"
  },
  "packageManager": "yarn@4.15.0",
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
